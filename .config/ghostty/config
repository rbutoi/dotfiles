# This is the configuration file for Ghostty.
#
# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#
# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.

background-opacity = 0.95
background-blur = true
font-family = SF Mono
font-size = 14

confirm-close-surface = false
macos-non-native-fullscreen = visible-menu
# macos-option-as-alt = true

shell-integration-features = ssh-terminfo

#
# Keybinds
#

keybind = alt+shift+r=reload_config

# --- Navigation ---
keybind = alt+shift+n=next_tab
keybind = alt+shift+p=previous_tab
keybind = alt+c=new_tab
keybind = alt+shift+f=goto_split:next
keybind = alt+shift+b=goto_split:previous

# --- Splits ---
keybind = alt+\=new_split:right
keybind = alt+-=new_split:down
keybind = alt+shift+==equalize_splits

# --- Resizing ---
keybind = super+z=toggle_split_zoom
keybind = ctrl+shift+up=resize_split:up,60
keybind = ctrl+shift+down=resize_split:down,60
keybind = ctrl+shift+left=resize_split:left,60
keybind = ctrl+shift+right=resize_split:right,60

keybind = global:cmd+shift+grave_accent=toggle_quick_terminal


# MacOS note:
#
# Emacs needs TERMINFO set at process launch time to read the terminfo
# db. Setting it by `emacsclient` is too late. Setting it even after startup
# with `exec-path-from-shell` is too late. So:
#
# > cp -Rs /Applications/kitty.app/Contents/Resources/kitty/terminfo ~/.terminfo &&
#   cp -Rs /Applications/Ghostty.app/Contents/Resources/terminfo     ~/.terminfo